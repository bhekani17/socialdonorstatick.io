{
    "name": "socialdonor/platform",
    "description": "Social Donor Blood Donation Platform - PHP Backend",
    "version": "1.0.0",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Social Donor Team",
            "email": "admin@socialdonor.org"
        }
    ],
    "require": {
        "php": "^8.0",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "ext-fileinfo": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "squizlabs/php_codesniffer": "^3.6",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "suggest": {
        "ext-mongodb": "For MongoDB support (optional)",
        "mongodb/mongodb": "MongoDB PHP driver for advanced features"
    },
    "autoload": {
        "psr-4": {
            "SocialDonor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SocialDonor\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "security-check": "composer audit",
        "setup": "php setup_test.php"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "*": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "keywords": [
        "blood donation",
        "healthcare",
        "social impact",
        "php",
        "mysql",
        "donor management"
    ],
    "homepage": "https://socialdonor.org",
    "support": {
        "email": "support@socialdonor.org",
        "docs": "https://docs.socialdonor.org",
        "issues": "https://github.com/socialdonor/issues"
    }
}
